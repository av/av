include mixins/shape

section.intro
  -
    // Seeded PRNG so decorations are stable across builds
    let _seed = 1;
    const rng = () => { _seed = (_seed * 16807 + 0) % 2147483647; return (_seed - 1) / 2147483646; };
    const pick = (arr) => arr[Math.floor(rng() * arr.length)];

    const colorPairs = [
      ['--amber',   '--tertiary'],
      ['--primary', '--tertiary'],
      //- ['--primary', '--lime'],
      //- ['--tertiary','--red'],
      //- ['--primary', '--amber'],
      //- ['--amber',   '--primary'],
      //- ['--lime',    '--tertiary'],
    ];
    const allAnimations = ['stronger-shaking', 'shaking'];
    const COUNT = 12;

    const SIZE_MIN = 100, SIZE_MAX = 300;
    const FORCE_MIN = 20, FORCE_MAX = 150;
    const REF_WIDTH = 1600;
    const MOBILE_MIN_PX = 60;
    const decorations = Array.from({ length: COUNT }, () => {
      const sizePx = Math.round(Math.pow(rng(), 3) * (SIZE_MAX - SIZE_MIN) + SIZE_MIN);
      const sizeVw = (sizePx / REF_WIDTH * 100).toFixed(2);
      // Size → force: large shapes move fast, small shapes move slow.
      // A ±15% jitter keeps similarly-sized shapes from moving in lockstep.
      const baseForce = FORCE_MIN + ((sizePx - SIZE_MIN) / (SIZE_MAX - SIZE_MIN)) * (FORCE_MAX - FORCE_MIN);
      const force = Math.round(baseForce * (0.85 + rng() * 0.30));
      return {
        force,
        sizeVw,
        variation:  Math.round(rng() * 30  + 55),
        animations: [pick(allAnimations)],
        colors:     pick(colorPairs),
        top:        Math.round(rng() * 110 - 5),
        // Cap left so no shape escapes the right viewport edge and causes
        // a horizontal scrollbar. Largest shape is ~19vw wide; left ≤ 80%
        // ensures left + width stays within ~99% of the section width.
        left:       Math.round(rng() * 85 - 5),
      };
    });

  .decorations-layer
    each d in decorations
      .decoration(data-force=d.force style=`top:${d.top}%;left:${d.left}%;--sz-vw:${d.sizeVw}vw;--sz-min:${MOBILE_MIN_PX}px`)
        +shape({ size: `${d.sizeVw}vw`, variation: d.variation, animations: d.animations, colors: d.colors })

  .content(flex-column justify-center)
    .raised
      h1.intro-name
        span(data-aos="fade-up" data-aos-easing="ease-out-sine") Ivan
        span(data-aos="fade-up") &nbsp;
        span(data-aos="fade-up" data-aos-delay=50 data-aos-duration=400) Charapanau
      p.intro-hero(data-aos="fade-up" data-aos-delay=150)
        span AI Systems Architect

      .pills(flex-row flex-wrap)
        .pill.inverse(data-target="section.career" data-aos="fade-up" data-aos-delay=200) Achievements
        .pill.inverse(data-target="section.skills" data-aos="fade-up" data-aos-delay=250) Skills
        .pill.inverse(data-target="section.contacts" data-aos="fade-up" data-aos-delay=300) Contacts
        a.intro-blog-link(href="/blog/" data-aos="fade-up" data-aos-delay=350)
          .pill.inverse Blog
        a.download-pdf(href="/src/pdf/Ivan Charapanau, AI Systems Architect.pdf" download="Ivan Charapanau, AI Systems Architect"  data-aos="fade-up" data-aos-delay=350 data-aos-duration=500)
          .pill
            i.gg-software-download
            span Resume

      .scroll-invitation(flex-row flex-center)
        i.gg-mouse

link(rel="stylesheet" href="./intro.scss")
